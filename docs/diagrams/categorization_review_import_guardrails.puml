@startuml
title review-import Guardrails and Decision Flow

start
:Resolve review + transaction override + review state paths;
:Load transaction override store;

if (override load warnings?) then (yes)
  if (--allow-load-warnings?) then (yes)
    :Print warnings and continue;
  else (no)
    :Abort import (exit=1);
    stop
  endif
endif

:Read review table;
:Check required columns;

repeat
  :Read next review row;
  if (row exists?) then (yes)
    if (category/subcategory edit requested?) then (yes)
      if (transaction_id present?) then (yes)
        if (category present?) then (yes)
          if (category == Uncategorized?) then (yes)
            :Skip category action;
          else (no)
            :Build transaction category override entry;
          endif
        else (no)
          if (subcategory present?) then (yes)
            :Skip row (invalid category action);
          endif
        endif
      else (no)
        :Skip row (missing transaction_id for category edit);
      endif
    endif

    if (project_tags populated?) then (yes)
      if (transaction_id present?) then (yes)
        :Build transaction project-tags entry;
      else (no)
        :Skip row (invalid project tags);
      endif
    endif

    if (reviewed/review_comment populated?) then (yes)
      if (transaction_id present?) then (yes)
        :Build review-state update entry;
      else (no)
        :Skip review-state update;
      endif
    endif
  endif
repeat while (more rows?) is (yes)

:Upsert transaction entries in-memory;
:Upsert review-state entries in-memory;
if (--dry-run?) then (yes)
  :Return counters only;\nNo write;
  stop
endif

if (--backup?) then (yes)
  :Create backup for changed transaction override file\n(default timestamp or --backup-path);
endif

:Write merged transaction overrides file;
:Write review state file;
:Return counters and backup path;
stop

@enduml
