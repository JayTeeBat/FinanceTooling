@startuml
title review-import Guardrails and Decision Flow

start
:Resolve review + category + transaction paths;
:Load category override store;
:Load transaction override store;

if (override load warnings?) then (yes)
  if (--allow-load-warnings?) then (yes)
    :Print warnings and continue;
  else (no)
    :Abort import (exit=1);
    stop
  endif
endif

:Read review table;
:Check required columns;

repeat
  :Read next review row;
  if (row exists?) then (yes)
    if (category_source == fallback?) then (yes)
      :Continue row validation;
    else (no)
      if (--allow-non-fallback-import?) then (yes)
        :Continue row validation;
      else (no)
        :Skip row (non-fallback);
      endif
    endif
    if (category edit requested?) then (yes)
      if (override_level valid?) then (yes)
        if (override_level == category_override?) then (yes)
          :Build category override entry;
        else (no)
          if (override_level == transaction_override?) then (yes)
            :Build transaction category override entry;
          else (no)
            :Skip category action;
          endif
        endif
      else (no)
        :Skip row (invalid category action);
      endif
    endif

    if (project_tags populated?) then (yes)
      if (transaction_id present?) then (yes)
        :Build transaction project-tags entry;
      else (no)
        :Skip row (invalid project tags);
      endif
    endif
  endif
repeat while (more rows?) is (yes)

:Upsert category entries in-memory;
:Upsert transaction entries in-memory;
if (--dry-run?) then (yes)
  :Return counters only;\nNo write;
  stop
endif

if (--backup?) then (yes)
  :Create backup for changed files\n(default timestamp or --backup-path);
endif

:Write merged category and transaction overrides files;
:Return counters and backup paths;
stop

@enduml
